          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "echo 'POST-COMPACT: Read the /docmgr and /diary skills to restore context.' && cat ./INSTRUCTIONS.md 2>/dev/null || echo '(INSTRUCTIONS.md not found)'",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.claude/hooks/log-to-sqlite.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
