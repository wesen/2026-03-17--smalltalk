{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/diary-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'POST-COMPACT: Read the /docmgr and /diary skills to restore context.' && cat ./INSTRUCTIONS.md 2>/dev/null || echo '(INSTRUCTIONS.md not found)'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
